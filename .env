# .env file - Choose your database

# For SQLite (default, no additional setup)
DATABASE_URL=sqlite:///data/tender_system.db
DB_TYPE=sqlite

# For PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/tenderai
# DB_TYPE=postgresql

# For MySQL/MariaDB
# DATABASE_URL=mysql://user:password@localhost:3306/tenderai
# DB_TYPE=mysql

# For CockroachDB
# DATABASE_URL=cockroachdb://user:password@localhost:26257/tenderai
# DB_TYPE=cockroachdb

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30