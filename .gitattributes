# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf

# Shell scripts
*.sh text eol=lf

# Batch files
*.bat text eol=crlf

# JSON files
*.json text eol=lf

# Markdown files
*.md text eol=lf

# SQL files
*.sql text eol=lf

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
*.db binary
*.sqlite binary
